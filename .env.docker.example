# Copy this next to docker-compose.yml on the server (do not commit secrets).
MEDIA_BASE_URL=https://static.cf.nyaneko.cn/gallery
GALLERY_HTTP_PORT=8088

# Host path for catalog + cache + temp upload batches.
# photos-index.json lives here so you can edit/replace it without entering the container.
GALLERY_DATA_HOST_PATH=./data/gallery

# Host path to R2/upload credentials (never commit this file).
UPLOAD_ENV_HOST_PATH=./script/upload_r2.env
UPLOAD_ACCESS_TOKEN=

BACKEND_IMAGE=ghcr.io/kohakunamori/gallery-backend:latest
FRONTEND_IMAGE=ghcr.io/kohakunamori/gallery-frontend:latest
