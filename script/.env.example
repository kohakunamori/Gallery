# Copy this file to one of: .env, .env.local, upload_r2.env, r2.env
# CLI arguments override values from env files.
# Fill only the sections for the targets you actually use.

# =========================
# Shared
# =========================
# Valid values: avif-lossless, png, none
UPLOAD_COMPRESSION=avif-lossless

# Local gallery catalog (photos-index.json) when the script runs ON the API host.
# After R2 upload succeeds, new items are merge-upserted into this file by path.
# Examples:
#   PHOTO_CATALOG_PATH=./data/gallery/photos-index.json
# CLI --catalog overrides this value when both are set.
PHOTO_CATALOG_PATH=

# Remote gallery catalog when the script runs on a DIFFERENT machine than the API.
# Uses LINUX_UPLOAD_* SSH only to SFTP get/merge/put this JSON (does NOT upload images).
# Examples:
#   PHOTO_CATALOG_REMOTE_PATH=/home/you/gallery/data/gallery/photos-index.json
# CLI --catalog-remote overrides this value.
PHOTO_CATALOG_REMOTE_PATH=

# =========================
# R2 / S3-compatible upload
# =========================
# Set R2_ENDPOINT directly, or set CLOUDFLARE_ACCOUNT_ID and let the script derive it.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET=static-bucket
R2_PREFIX=gallery
R2_ENDPOINT=
R2_REGION=auto
R2_PROXY=

# Optional AWS-compatible aliases.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_DEFAULT_REGION=

# =========================
# Linux SSH (optional)
# =========================
# Used for either:
#   1) --target linux|both|all  → upload image files via SFTP
#   2) PHOTO_CATALOG_REMOTE_PATH / --catalog-remote → only merge-update photos-index.json
# Provide either LINUX_UPLOAD_KEY or LINUX_UPLOAD_PASSWORD.
LINUX_UPLOAD_HOST=
LINUX_UPLOAD_USER=
LINUX_UPLOAD_DIR=
LINUX_UPLOAD_KEY=
LINUX_UPLOAD_PASSWORD=
LINUX_UPLOAD_PORT=22
LINUX_PROXY=

# =========================
# Qiniu upload
# =========================
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_PREFIX=gallery
