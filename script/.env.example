# Copy this file to .env or .env.local and fill in the values you actually use.
# If you only want to upload to R2, run: python upload_r2.py --target r2
# If you only want to upload to Linux, run: python upload_r2.py --target linux
# If you only want to upload to Qiniu, run: python upload_r2.py --target qiniu
# The default target is `both`, which is normalized to `all` in upload_r2.py
# and will try R2 + Linux + Qiniu together.

# =========================
# R2 / S3-compatible upload
# =========================
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET=
R2_PREFIX=gallery
R2_ENDPOINT=
R2_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_DEFAULT_REGION=
R2_PROXY=

# =========================
# Linux upload over SSH/SFTP
# =========================
LINUX_UPLOAD_HOST=
LINUX_UPLOAD_USER=
LINUX_UPLOAD_DIR=
LINUX_UPLOAD_KEY=
LINUX_UPLOAD_PASSWORD=
LINUX_UPLOAD_PORT=22
LINUX_PROXY=

# =========================
# Qiniu upload
# =========================
# Set QINIU_BUCKET explicitly. Do not rely on the R2 bucket fallback.
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_PREFIX=gallery
