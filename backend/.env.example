# Copy this file to backend/.env and fill in real values.
# Keep backend/.env out of version control.

# Optional overrides for remote media + catalog storage.
# MEDIA_BASE_URL="https://static.cf.nyaneko.cn/gallery"
# PHOTO_CATALOG_PATH="/path/to/backend/var/photos-index.json"
# UPLOAD_PYTHON_BINARY="/opt/gallery-python/bin/python"

# Optional: env file passed to script/upload_r2.py via --env-file.
UPLOAD_SCRIPT_ENV_FILE="/www/wwwroot/aigc.nyaneko.cn/script/upload_r2.env"
UPLOAD_TEMPORARY_DIRECTORY="/www/wwwroot/aigc.nyaneko.cn/backend/var/upload-batches"
UPLOAD_ACCESS_TOKEN=""
